# Template for environment variables used by maintenance scripts in scripts/.
# Copy this file to .env and fill in the real values. Never commit .env.

# N8N API (scripts/*.py read this via scripts/_env.py)
N8N_API_KEY=your_n8n_api_key_here
N8N_BASE_URL=https://ecommercepuro.app.n8n.cloud/api/v1

# Ecommerce Puro Admin API (used by fix-buscar-evento.py and N8N workflow)
ECOMMERCE_PURO_API_KEY=epk_your_key_here
ECOMMERCE_PURO_API_URL=https://admin.ecommercepuro.com.br/api

# Supabase (used by scripts/seed_super_admin.py)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt_here

# Dashboard super admin seed (run scripts/seed_super_admin.py once after first login)
SUPER_ADMIN_EMAIL=admin@your-company.com
SUPER_ADMIN_DISPLAY_NAME=Admin Name
